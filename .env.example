# 玄照 v2.0 配置示例
# 复制此文件为 .env 并填写实际值

# LLM API 密钥（必填，用于视角推理/辩论综合/溟玄审查）
XUANZHAO_API_KEY=your_api_key_here

# LLM API 地址
XUANZHAO_API_BASE=https://token-plan-sgp.xiaomimimo.com/v1

# LLM 模型名称
XUANZHAO_MODEL=mimo-v2-pro

# LLM 超时（秒）
XUANZHAO_TIMEOUT=120

# 服务配置
XUANZHAO_HOST=0.0.0.0
XUANZHAO_PORT=8000
XUANZHAO_WORKERS=1

# 调试模式
DEBUG=false

# 环境（dev/prod）
XUANZHAO_ENV=prod
